    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Create a bar chart showing who survived (1) vs died (0)\n",
    "sns.countplot(x='Survived', data=df)\n",
    "\n",
    "# Add titles so it looks professional\n",
    "plt.title('Count of Passengers: Saved (1) vs Lost (0)')\n",
    "plt.xlabel('Survived Status')\n",
    "plt.ylabel('Number of Passengers')\n",
    "\n",
    "# Show the chart\n",
    "plt.show()"
   ]
